    "triggers": [
      {
        "title": {
          "en": "Button pressed"
        },
        "hint": {
          "en": "Fires when the physical button on top of the device is pressed."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "title": {
              "en": "Device"
            },
            "filter": "driver_id=thirdreality-voice--music-assistant"
          }
        ],
        "tokens": [
          {
            "name": "event",
            "type": "string",
            "title": {
              "en": "Event type"
            },
            "example": {
              "en": "single_press"
            }
          }
        ],
        "id": "button-pressed"
      },
      {
        "title": {
          "en": "Timer cancelled"
        },
        "hint": {
          "en": "Fires when a running or ringing timer is cancelled (by voice, a flow, or being replaced)."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "title": {
              "en": "Device"
            },
            "filter": "driver_id=home-assistant-voice-preview-edition|xiaozhi-ai"
          }
        ],
        "tokens": [
          {
            "name": "name",
            "type": "string",
            "title": {
              "en": "Name"
            },
            "example": {
              "en": "pasta"
            }
          },
          {
            "name": "duration",
            "type": "number",
            "title": {
              "en": "Duration (seconds)"
            },
            "example": 1200
          }
        ],
        "id": "timer-cancelled"
      },
      {
        "title": {
          "en": "Timer finished"
        },
        "hint": {
          "en": "Fires when a timer or alarm reaches zero and the device starts ringing."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "title": {
              "en": "Device"
            },
            "filter": "driver_id=home-assistant-voice-preview-edition|xiaozhi-ai"
          }
        ],
        "tokens": [
          {
            "name": "name",
            "type": "string",
            "title": {
              "en": "Name"
            },
            "example": {
              "en": "pasta"
            }
          },
          {
            "name": "duration",
            "type": "number",
            "title": {
              "en": "Duration (seconds)"
            },
            "example": 1200
          }
        ],
        "id": "timer-finished"
      },
      {
        "title": {
          "en": "Timer started"
        },
        "hint": {
          "en": "Fires when a timer or alarm starts counting down on the device."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "title": {
              "en": "Device"
            },
            "filter": "driver_id=home-assistant-voice-preview-edition|xiaozhi-ai"
          }
        ],
        "tokens": [
          {
            "name": "name",
            "type": "string",
            "title": {
              "en": "Name"
            },
            "example": {
              "en": "pasta"
            }
          },
          {
            "name": "duration",
            "type": "number",
            "title": {
              "en": "Duration (seconds)"
            },
            "example": 1200
          }
        ],
        "id": "timer-started"
      }
    ],
    "conditions": [
      {
        "title": {
          "en": "Is muted"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "title": {
              "en": "Device"
            },
            "filter": "driver_id=home-assistant-voice-preview-edition|thirdreality-voice--music-assistant"
          }
        ],
        "id": "is-muted"
      },
      {
        "title": {
          "en": "A timer !{{is|is not}} running"
        },
        "hint": {
          "en": "True while a timer or alarm is counting down. A finished (ringing) timer does not count as running."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "title": {
              "en": "Device"
            },
            "filter": "driver_id=home-assistant-voice-preview-edition|xiaozhi-ai"
          }
        ],
        "id": "timer-is-running"
      }
    ],
    "actions": [
      {
        "title": {
          "en": "Ask assistant. Output as text"
        },
        "titleFormatted": {
          "en": "Ask assistant [[Question]]. Output as text"
        },
        "hint": {
          "en": "Send an inquiry to the AI assistant, the response will be in a text variable"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "title": {
              "en": "Device"
            },
            "filter": "driver_id=home-assistant-voice-preview-edition|xiaozhi-ai|thirdreality-voice--music-assistant"
          },
          {
            "type": "text",
            "name": "Question",
            "title": {
              "en": "Question"
            },
