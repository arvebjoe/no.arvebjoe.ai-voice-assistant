      {
        "title": {
          "en": "Cancel the timer"
        },
        "hint": {
          "en": "Cancel the running timer, or stop the timer/alarm currently ringing on the device."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "title": {
              "en": "Device"
            },
            "filter": "driver_id=home-assistant-voice-preview-edition|xiaozhi-ai"
          }
        ],
        "id": "cancel-timer"
      },
      {
        "title": {
          "en": "Playback audio from URL"
        },
        "titleFormatted": {
          "en": "Playback audio from [[Url]]"
        },
        "hint": {
          "en": "Play any (local or remote) web URL as long as it's flac format"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "title": {
              "en": "Device"
            },
            "filter": "driver_id=home-assistant-voice-preview-edition|xiaozhi-ai|thirdreality-voice--music-assistant"
          },
          {
            "type": "text",
            "name": "Url",
            "title": {
              "en": "Url"
            },
            "placeholder": {
              "en": "Url"
            }
          }
        ],
        "id": "playback-audio-from-url"
      },
      {
        "title": {
          "en": "Say"
        },
        "titleFormatted": {
          "en": "Say [[text]]"
        },
        "hint": {
          "en": "Convert text to speech and play it"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "title": {
              "en": "Device"
            },
            "filter": "driver_id=home-assistant-voice-preview-edition|xiaozhi-ai|thirdreality-voice--music-assistant"
          },
          {
            "type": "text",
            "name": "text",
            "title": {
              "en": "text"
            },
            "placeholder": {
              "en": "text"
            }
          }
        ],
        "id": "speak-text"
      },
      {
        "title": {
          "en": "Start a timer"
        },
        "titleFormatted": {
          "en": "Start a [[duration]] second timer named [[name]]"
        },
        "hint": {
          "en": "Start a countdown timer on the device. Replaces any timer already running (only one timer can exist at a time)."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "title": {
              "en": "Device"
            },
            "filter": "driver_id=home-assistant-voice-preview-edition|xiaozhi-ai"
          },
          {
            "type": "number",
            "name": "duration",
            "title": {
              "en": "Duration (seconds)"
            },
            "min": 1,
            "step": 1,
            "placeholder": {
              "en": "1200"
            }
          },
          {
            "type": "text",
            "name": "name",
            "title": {
              "en": "Name"
            },
            "placeholder": {
              "en": "pasta"
            }
          }
        ],
        "id": "start-timer"
      }
    ]
  },
