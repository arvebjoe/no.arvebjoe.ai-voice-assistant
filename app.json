      },
      {
        "title": {
          "en": "Ask agent. Output to speaker"
        },
        "titleFormatted": {
          "en": "Ask assistant [[Question]]. Output to speaker"
        },
        "hint": {
          "en": "Send an inquiry to the AI assistant, the response will play on this device"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "title": {
              "en": "Device"
            },
            "filter": "driver_id=home-assistant-voice-preview-edition|xiaozhi-ai|thirdreality-voice--music-assistant"
          },
          {
            "type": "text",
            "name": "Question",
            "title": {
              "en": "Question"
            },
            "placeholder": {
              "en": "Question"
            }
          }
        ],
        "id": "ask-agent-output-to-speaker"
